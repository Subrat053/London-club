<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= appName || 'London Club' %> | Manager Portal</title>
  <style>
    body { margin: 0; font-family: Arial, sans-serif; background: #f7f8fc; color: #1f2937; }
    .wrap { max-width: 920px; margin: 0 auto; padding: 24px 16px; }
    h1 { margin: 0 0 6px; }
    .meta { color: #6b7280; margin: 0 0 14px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }
    .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 14px; }
    .card h3 { margin: 0 0 8px; }
    .card p { margin: 0 0 10px; color: #6b7280; font-size: 13px; }
    .btn { display: inline-block; text-decoration: none; font-size: 13px; border: 1px solid #d1d5db; color: #111827; border-radius: 8px; padding: 8px 11px; font-weight: 700; }
  </style>
</head>

<body>
  <div class="wrap">
    <h1>Manager Portal</h1>
    <p class="meta">Types defined: <%= userTypes.join(', ') %>. Current type: <%= currentType %>.</p>
    <div class="grid">
      <div class="card">
        <h3>Manager Dashboard</h3>
        <p>Daily controls and operation overview.</p>
        <a class="btn" href="/manager">Open Dashboard</a>
      </div>
      <div class="card">
        <h3>Recharge Queue</h3>
        <p>Review and process pending deposits.</p>
        <a class="btn" href="/manager/recharge">Open Recharge</a>
      </div>
      <div class="card">
        <h3>Withdraw Queue</h3>
        <p>Review and process pending withdrawals.</p>
        <a class="btn" href="/manager/withdraw">Open Withdraw</a>
      </div>
      <div class="card">
        <h3>User Portal</h3>
        <p>Switch to standard user functionality.</p>
        <a class="btn" href="/portal/user">Open User Portal</a>
      </div>
    </div>
  </div>
</body>

</html>
