    <script>
        const alertMess = (text, sic) => {
            $('body').append(
                `
                    <div data-v-1dcba851="" class="msg">
                        <div data-v-1dcba851="" class="msg-content v-enter-active v-enter-to" style=""> ${text} </div>
                    </div>
                    `
            );
            setTimeout(() => {
                $('.msg .msg-content').removeClass('v-enter-active v-enter-to');
                $('.msg .msg-content').addClass('v-leave-active v-leave-to');
                setTimeout(() => {
                    $('.msg').remove();
                }, 100);
                sic.removeClass('block-click');
            }, 1000);
        }

        $(document).ready(function () {
            $('.van-overlay').fadeIn(10);
        });
        $(window).on('load',
            function () {
                $('.van-overlay').fadeIn(10);
                $.ajax({
                    type: "POST",
                    url: "/api/webapi/safeHistory",
                    data: {},
                    dataType: "json",
                    success: function (response) {
                        if (response.status) {
                            const { safeList } = response.data;
                            if(safeList.length > 0){
                             let text=``;
                             for(let i of safeList){
                                text+=` <div data-v-6cfd8c1d="" data-v-002ff529=""
                        class="StrongBoxRecordCard__container StrongBox__container-record-card">
                        <div data-v-6cfd8c1d="" class="StrongBoxRecordCard__container-first">
                            <div data-v-6cfd8c1d="" class="StrongBoxRecordCard__container-buttom" style="${i.type == 'Transfer In' ? 'background-color: #61a9ff;color: #f0f1f5;':""}">${i.type}</div>
                            <div data-v-6cfd8c1d="" class="StrongBoxRecordCard__container-num">${i.type == 'Transfer In' ? '+': '-'}₹${i.amount}</div>
                        </div>
                        <div data-v-6cfd8c1d="" class="StrongBoxRecordCard__container-rale"><span
                                data-v-6cfd8c1d="">Daily interest rate</span><span data-v-6cfd8c1d="">0.10%</span></div>
                        <div data-v-6cfd8c1d="" class="StrongBoxRecordCard__container-rale"><span
                                data-v-6cfd8c1d="">Payout income</span><span data-v-6cfd8c1d=""
                                class="StrongBoxRecordCard__container-rale-num">₹${i.type == 'Transfer In' ? '0.00':i.interest_amount}</span></div>
                        <div data-v-6cfd8c1d="" class="StrongBoxRecordCard__container-last"><span
                                data-v-6cfd8c1d="">${i.transcationId}</span><span data-v-6cfd8c1d="">${i.time}</span></div>
                    </div>`
                             }
                             $('.safe-history').html(text);
                            }
                            else{
                                let text=`<div data-v-31900034="" class="list p-t-80">
                <div data-v-31900034="" class="van-empty">
                    <div class="van-empty__image"><img src="/images/empty-image-default.png" /></div>
                    <p class="van-empty__description">No Data</p>
                </div>
            </div>`
            $('.safe-history').html(text);
                            }
                            
                            setTimeout($('.van-overlay').fadeOut(300), 500);
                        }
                        else {
                            setTimeout(alertMess(response.message, $(this)), 350)
                            setTimeout($('.van-overlay').fadeOut(300), 500)
                        }
                    }
                });

            });

    </script>
